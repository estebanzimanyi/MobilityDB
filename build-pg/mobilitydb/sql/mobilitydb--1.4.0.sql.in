  RETURNS intspan[]
  AS 'MODULE_PATHNAME', 'Spanset_bins'
  LANGUAGE C IMMUTABLE PARALLEL SAFE STRICT;
CREATE FUNCTION bins(bigintspanset, vsize bigint, vorigin int DEFAULT 0)
  RETURNS intspan[]
  AS 'MODULE_PATHNAME', 'Spanset_bins'
  LANGUAGE C IMMUTABLE PARALLEL SAFE STRICT;
