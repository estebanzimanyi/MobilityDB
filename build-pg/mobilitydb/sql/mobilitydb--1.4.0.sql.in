CREATE AGGREGATE appendSequenceAgg(tcbuffer) (
  SFUNC = temporal_app_tseq_transfn,
  STYPE = tcbuffer,
  FINALFUNC = temporal_append_finalfn,
  PARALLEL = safe
);

