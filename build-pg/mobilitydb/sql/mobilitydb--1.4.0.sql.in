/******************************************************************************
 * Multidimensional tiling
 ******************************************************************************/

CREATE TYPE time_tgeom AS (
  time timestamptz,
  tgeom tgeometry
);
CREATE TYPE time_tgeog AS (
  time timestamptz,
  tgeog tgeography
);

