-- maxdecimaldigits: significant digits to keep; -1 = lossless
CREATE FUNCTION asGeoPose(tpose, conformance int4 DEFAULT 0,
    maxdecimaldigits int4 DEFAULT -1)
  RETURNS text
  AS 'MODULE_PATHNAME', 'Tpose_as_geopose'
