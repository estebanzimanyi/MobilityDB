 *****************************************************************************/

CREATE FUNCTION tTouches(geometry, trgeometry)
  RETURNS tbool
  LANGUAGE SQL IMMUTABLE STRICT PARALLEL SAFE
  AS $$ SELECT tTouches($1, $2::tgeometry) $$;
CREATE FUNCTION tTouches(trgeometry, geometry)
