    origin timestamptz DEFAULT '2000-01-03')
  RETURNS setof time_tgeom
  AS 'MODULE_PATHNAME', 'Temporal_time_split'
  LANGUAGE C IMMUTABLE PARALLEL SAFE STRICT;
