/* Errors */
SELECT bodyPointTrajectory(
  trgeometry '{Polygon((0 0, 1 0, 1 1, 0 1, 0 0));[Pose(Point(0 0),0)@2026-01-01, Pose(Point(10 0),0)@2026-01-01 00:01:00]}',
  'Linestring(0 0, 1 1)');
ERROR:  Body-frame argument must be a Point, got Linestring
SELECT bodyPointTrajectory(
  trgeometry '{Polygon((0 0, 1 0, 1 1, 0 1, 0 0));[Pose(Point(0 0),0)@2026-01-01, Pose(Point(10 0),0)@2026-01-01 00:01:00]}',
  'PointZ(0 0 1)');
ERROR:  Body-point dimensionality (3D) must match trgeometry (2D)